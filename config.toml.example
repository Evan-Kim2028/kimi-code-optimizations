# Example ~/.kimi/config.toml snippet
# Add these [[hooks]] sections to your existing config.toml

[[hooks]]
event = "PreToolUse"
matcher = "Shell"
command = "python3 /home/evan/.kimi/hooks/shell-check.py"
timeout = 5

[[hooks]]
event = "PreToolUse"
matcher = "StrReplaceFile"
command = "python3 /home/evan/.kimi/hooks/strreplace-check.py"
timeout = 3

[[hooks]]
event = "PostToolUse"
matcher = ".*"
command = "python3 /home/evan/.kimi/hooks/batch-nudge.py"
timeout = 2
