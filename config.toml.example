# Example ~/.kimi/config.toml snippet
# Add this [[hooks]] section to your existing config.toml

[[hooks]]
event = "PreToolUse"
matcher = "Shell"
command = "python3 /path/to/kimi-code-optimizations/hooks/shell-check.py"
timeout = 10

[[hooks]]
event = "PreToolUse"
matcher = "StrReplaceFile"
command = "python3 /path/to/kimi-code-optimizations/hooks/strreplace-check.py"
timeout = 5

[[hooks]]
event = "PostToolUse"
matcher = ".*"
command = "python3 /path/to/kimi-code-optimizations/hooks/batch-nudge.py"
timeout = 5
