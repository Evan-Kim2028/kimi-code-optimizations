{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/kimi-code-optimizations/claude/hooks/edit-check.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/kimi-code-optimizations/claude/hooks/re-read-guard.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/kimi-code-optimizations/claude/hooks/parallel-agent-guard.py"
          },
          {
            "type": "command",
            "command": "python3 /path/to/kimi-code-optimizations/claude/hooks/cheap-subagent-router.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/kimi-code-optimizations/claude/hooks/web-tool-redirect.py"
          }
        ]
      }
    ]
  }
}
